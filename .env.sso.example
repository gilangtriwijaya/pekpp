### SSO API pull example
SSO_BASE_URL=https://sistagor.anambaskab.go.id
SSO_PULL_TOKEN=REPLACE_WITH_BEARER_TOKEN
# Optional: override endpoints
SSO_USERS_ENDPOINT=/api/sso/users
SSO_OPDS_ENDPOINT=/api/sso/opds

# Other SSO config
SSO_APP_CODE=pekpp
SSO_ALLOWED_REDIRECT_HOST=sistagor.anambaskab.go.id
